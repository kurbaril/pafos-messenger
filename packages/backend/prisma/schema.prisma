generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ChatType {
  PRIVATE
  GROUP
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  avatarUrl    String?
  bio          String?   @db.Text
  phone        String?
  email        String?   @unique
  pushToken    String?
  role         Role      @default(USER)
  isBanned     Boolean   @default(false)
  banReason    String?
  lastSeen     DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sentMessages Message[]   @relation("SenderMessages")
  reactions    Reaction[]
  chats        ChatUser[]
  groups       Group[]
  groupMembers GroupMember[]
  notifications Notification[]
  blockedUsers UserBlock[] @relation("Blocker")
  blockedBy    UserBlock[] @relation("Blocked")
  readMessages MessageRead[]
  mentions     Mention[]

  @@index([username])
  @@index([lastSeen])
}

model Chat {
  id        String    @id @default(cuid())
  type      ChatType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users    ChatUser[]
  messages Message[]
  group    Group?
  pinned   PinnedMessage?

  @@index([updatedAt])
}

model Message {
  id                 String      @id @default(cuid())
  content            String?     @db.Text
  fileUrl            String?
  fileType           String?
  fileName           String?
  fileSize           Int?
  duration           Int?
  quotedId           String?
  isDeletedForUsers  Boolean     @default(false)
  deletedAt          DateTime?
  deletedBy          String?
  editedAt           DateTime?
  createdAt          DateTime    @default(now())
  senderId           String
  chatId             String

  sender      User        @relation("SenderMessages", fields: [senderId], references: [id])
  chat        Chat        @relation(fields: [chatId], references: [id])
  quoted      Message?    @relation("QuotedMessage", fields: [quotedId], references: [id])
  reactions   Reaction[]
  readBy      MessageRead[]
  mentions    Mention[]
  editHistory MessageEdit[]
  pinned      PinnedMessage?

  @@index([chatId])
  @@index([createdAt])
  @@index([senderId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model MessageEdit {
  id         String   @id @default(cuid())
  messageId  String
  oldContent String?  @db.Text
  newContent String   @db.Text
  editedBy   String
  editedAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model Mention {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model PinnedMessage {
  id        String   @id @default(cuid())
  messageId String   @unique
  chatId    String   @unique
  pinnedBy  String
  pinnedAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  avatarUrl   String?
  ownerId     String
  chatId      String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner   User          @relation(fields: [ownerId], references: [id])
  chat    Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  members GroupMember[]

  @@index([ownerId])
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
}

model ChatUser {
  id       String   @id @default(cuid())
  userId   String
  chatId   String
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
  @@index([chatId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // message, reaction, mention, group_invite
  content   String   @db.Text
  data      Json?    // дополнительная информация (messageId, chatId, etc)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model UserBlock {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model BannedIP {
  id        String   @id @default(cuid())
  ip        String   @unique
  attempts  Int      @default(1)
  bannedAt  DateTime @default(now())
  expiresAt DateTime
  reason    String?

  @@index([ip])
  @@index([expiresAt])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String   // VIEW_CHAT, BAN_USER, UNBAN_USER, DELETE_MESSAGE, RESTORE_MESSAGE, VIEW_STATS
  targetId  String?  // ID пользователя/сообщения/чата
  metadata  Json?    // дополнительные данные
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
}

model DeletedMessageLog {
  id          String   @id @default(cuid())
  messageId   String
  deletedBy   String
  deletedAt   DateTime @default(now())
  messageData Json     // полная копия сообщения

  @@index([messageId])
  @@index([deletedBy])
  @@index([deletedAt])
}
