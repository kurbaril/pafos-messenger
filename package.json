{
  "name": "pafos-messenger",
  "version": "1.0.0",
  "description": "PaFos Messenger - Modern messaging app for friends",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/client",
    "packages/admin"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:client\" \"npm run dev:admin\"",
    "dev:backend": "cd packages/backend && npm run dev",
    "dev:client": "cd packages/client && npm run dev",
    "dev:admin": "cd packages/admin && npm run dev",
    "build": "npm run build:backend && npm run build:client && npm run build:admin",
    "build:backend": "cd packages/backend && npm run build",
    "build:client": "cd packages/client && npm run build",
    "build:admin": "cd packages/admin && npm run build",
    "start": "cd packages/backend && npm run start",
    "prisma:generate": "cd packages/backend && npm run prisma:generate",
    "prisma:migrate": "cd packages/backend && npm run prisma:migrate",
    "prisma:studio": "cd packages/backend && npm run prisma:studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist",
    "setup": "npm install && npm run prisma:generate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "PaFos Team",
  "license": "MIT"
}